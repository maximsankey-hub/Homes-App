generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PropertyStatus {
  NOT_VISITED
  VISITED
}

// A hard, self-enforced cap on outbound calls to metered third-party APIs (currently just
// RentCast) — not household-scoped, since it's a whole-app quota tied to one shared API key.
// `period` is a "YYYY-MM" string; a mismatch against the current month means the count has
// implicitly reset, without needing a scheduled job to zero it out.
model ApiUsage {
  id        String   @id @default(cuid())
  service   String   @unique
  period    String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt
}

enum MediaType {
  PHOTO
  VIDEO
  VOICE
}

enum RoomFeeling {
  EXCITED
  CALM
  UNCERTAIN
  OVERWHELMED
  INSPIRED
}

enum IdeaType {
  COSMETIC
  STRUCTURAL
}

enum DemandLevel {
  HIGH
  MODERATE
  LOW
}

enum ScorerRole {
  SELF
  PARTNER
}

enum MetricCategory {
  EMOTIONAL
  FUNCTIONAL
}

enum ProfileMethod {
  TAGS
  FREE_TEXT
  BOTH
}

enum TagSource {
  MANUAL
  AI_MAPPED
}

enum PlaceCategory {
  GROCERY
  PARKS
  SCHOOLS
  COFFEE
  GYMS
  FITNESS
  RESTAURANTS
  OTHER
}

enum CompDiffType {
  ABOVE
  BELOW
  WITHIN
}

enum MetricScope {
  ROOM
  PROPERTY
}

model Household {
  id         String   @id @default(cuid())
  inviteCode String   @unique
  createdAt  DateTime @default(now())

  members       Scorer[]
  properties    Property[]
  profile       PreferenceProfile?
  listing       Listing?
  customMetrics CustomMetric[]
}

model CustomMetric {
  id          String         @id @default(cuid())
  householdId String
  household   Household      @relation(fields: [householdId], references: [id])
  label       String
  category    MetricCategory
  scope       MetricScope    @default(ROOM)
  targetRoomName String?
  // Tags a metric as having been added via a priority topic's "add your own" row (matches a
  // PRIORITY_GROUPS key on the client) rather than being a catalog item or a fully free-form
  // one from the Profile screen's generic "Custom scoring metrics" card. Null for both of those.
  topicKey    String?
  weight      Int            @default(5)
  createdAt   DateTime       @default(now())

  scores         CustomMetricScore[]
  propertyScores PropertyMetricScore[]

  @@unique([householdId, label])
}

model Property {
  id            String         @id @default(cuid())
  householdId   String
  household     Household      @relation(fields: [householdId], references: [id])
  isDemo        Boolean        @default(false)
  address       String
  city          String
  state         String
  listingPrice  Int
  sqft          Int
  beds          Int
  baths         Int
  yearBuilt     Int?
  status        PropertyStatus @default(NOT_VISITED)
  lastVisitedAt DateTime?
  lat           Float?
  lng           Float?
  placesFetchedAt DateTime?

  walkScore    Int?
  transitScore Int?
  bikeScore    Int?

  safetyScore     Int?
  noiseScore      Int?
  greenSpaceScore Int?
  sidewalkScore   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rooms              Room[]
  media              Media[]
  renovations        RenovationIdea[]
  nearbyPlaces       NearbyPlace[]
  scorerNotes        ScorerNote[]
  neighborhoodScores NeighborhoodScore[]
  propertyMetricScores PropertyMetricScore[]
}

model ScorerNote {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  scorerId   String
  scorer     Scorer   @relation(fields: [scorerId], references: [id])
  text       String
  updatedAt  DateTime @updatedAt

  @@unique([propertyId, scorerId])
}

model Room {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name       String
  icon       String
  createdAt  DateTime @default(now())

  scores RoomScore[]
  media  Media[]

  @@unique([propertyId, name])
}

model Scorer {
  id              String     @id @default(cuid())
  householdId     String
  household       Household  @relation(fields: [householdId], references: [id])
  supabaseUserId  String?    @unique
  name            String
  role            ScorerRole
  initials        String
  colorHex        String
  contact         String?
  createdAt       DateTime   @default(now())

  scores             RoomScore[]
  notes              ScorerNote[]
  neighborhoodScores NeighborhoodScore[]
  propertyMetricScores PropertyMetricScore[]
  styleSwipes StyleSwipe[]
}

model RoomScore {
  id        String      @id @default(cuid())
  roomId    String
  room      Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  scorerId  String
  scorer    Scorer      @relation(fields: [scorerId], references: [id])
  layout    Int
  storage   Int
  light     Int
  vibe      Int
  feeling   RoomFeeling
  note      String?
  createdAt DateTime    @default(now())

  customScores CustomMetricScore[]

  @@unique([roomId, scorerId])
}

model CustomMetricScore {
  id          String       @id @default(cuid())
  roomScoreId String
  roomScore   RoomScore    @relation(fields: [roomScoreId], references: [id], onDelete: Cascade)
  metricId    String
  metric      CustomMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  value       Int

  @@unique([roomScoreId, metricId])
}

model NeighborhoodScore {
  id         String      @id @default(cuid())
  propertyId String
  property   Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  scorerId   String
  scorer     Scorer      @relation(fields: [scorerId], references: [id])
  curbAppeal Int
  streetVibe Int
  feeling    RoomFeeling
  note       String?
  createdAt  DateTime    @default(now())

  @@unique([propertyId, scorerId])
}

model PropertyMetricScore {
  id         String       @id @default(cuid())
  propertyId String
  property   Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  scorerId   String
  scorer     Scorer       @relation(fields: [scorerId], references: [id])
  metricId   String
  metric     CustomMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)
  value      Int
  createdAt  DateTime     @default(now())

  @@unique([propertyId, scorerId, metricId])
}

model Media {
  id               String          @id @default(cuid())
  propertyId       String
  property         Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomId           String?
  room             Room?           @relation(fields: [roomId], references: [id])
  renovationIdeaId String?
  renovationIdea   RenovationIdea? @relation(fields: [renovationIdeaId], references: [id], onDelete: Cascade)
  type             MediaType
  filePath         String
  mimeType         String
  sizeBytes        Int
  createdAt        DateTime        @default(now())
}

model RenovationIdea {
  id             String   @id @default(cuid())
  propertyId     String
  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  title          String
  room           String?
  type           IdeaType
  costLow        Int
  costHigh       Int
  feasibility    Int
  need           String?
  constraintNote String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  media Media[]
}

model NearbyPlace {
  id           String        @id @default(cuid())
  propertyId   String
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  name         String
  category     PlaceCategory
  distanceText String
  score        Float
  icon         String
  iconColor    String
  iconBg       String
  lat          Float?
  lng          Float?
}

// Curated content, shared across every household (not household-scoped) — a "Modern kitchen"
// photo is the same regardless of who's looking at it. Only the swipe responses are personal.
model StylePhoto {
  id        String   @id @default(cuid())
  roomType  String
  styleName String
  imageUrl  String
  createdAt DateTime @default(now())

  swipes StyleSwipe[]
}

model StyleSwipe {
  id           String     @id @default(cuid())
  scorerId     String
  scorer       Scorer     @relation(fields: [scorerId], references: [id])
  stylePhotoId String
  stylePhoto   StylePhoto @relation(fields: [stylePhotoId], references: [id], onDelete: Cascade)
  liked        Boolean
  createdAt    DateTime   @default(now())

  @@unique([scorerId, stylePhotoId])
}

model PreferenceProfile {
  id              String        @id @default(cuid())
  householdId     String        @unique
  household       Household     @relation(fields: [householdId], references: [id])
  method          ProfileMethod @default(BOTH)
  freeText        String?
  weightEmotional Int           @default(5)
  weightStorage   Int           @default(5)
  weightLight     Int           @default(5)
  weightNeighborhood Int        @default(5)
  aestheticStyle  String?
  hasPets                    Boolean       @default(false)
  petTypes                   String[]      @default([])
  householdComposition       String?
  householdCompositionOther  String?
  priorityBudgetVsDream      Int           @default(5)
  priorityMoveInReadyVsReno  Int           @default(5)
  updatedAt       DateTime      @updatedAt

  tags PreferenceTag[]
}

model PreferenceTag {
  id        String            @id @default(cuid())
  profileId String
  profile   PreferenceProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  label     String
  source    TagSource         @default(MANUAL)
}

model Listing {
  id                   String    @id @default(cuid())
  householdId          String    @unique
  household            Household @relation(fields: [householdId], references: [id])
  address              String
  city                 String
  state                String
  listPrice            Int
  sqft                 Int
  beds                 Int
  baths                Int
  estValueLow          Int
  estValueHigh         Int
  confidenceScore      Float
  avgDaysOnMarket      Int
  pricePerSqft         Int
  buyerEmotionalAvg    Float
  buyerFunctionalAvg   Float
  marketStatus         String
  buyerViewsCount      Int
  walkabilityScore     Float
  parkAccessScore      Float
  privacyScore         Float
  schoolQualityScore   Float
  noiseLevelScore      Float
  buyerPriorityLight   Float
  buyerPriorityKitchen Float
  buyerPriorityStorage Float
  buyerPriorityLayout  Float
  fitHosting           Float
  fitWFH               Float
  fitOrganization      Float
  fitFamily            Float
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  comps        MarketComp[]
  roomScores   ListingRoomScore[]
  improvements ImprovementIdea[]
}

model MarketComp {
  id         String       @id @default(cuid())
  listingId  String
  listing    Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  address    String
  sqft       Int
  saleDate   DateTime
  price      Int
  diffType   CompDiffType
  diffAmount Int
  note       String?
}

model ListingRoomScore {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  roomName  String
  score     Float
}

model ImprovementIdea {
  id              String      @id @default(cuid())
  listingId       String
  listing         Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  title           String
  demandLevel     DemandLevel
  type            IdeaType
  valueLift       Int
  costLow         Int
  costHigh        Int
  feasibility     Int
  supportingNote1 String?
  supportingNote2 String?
  createdAt       DateTime    @default(now())
}
