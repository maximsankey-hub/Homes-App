# Supabase Postgres — Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# Supabase Storage — Project Settings > API
SUPABASE_URL="https://xxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_STORAGE_BUCKET="media"

# Auth — see README/plan for details. LEGACY_HOUSEHOLD_OWNER_EMAIL should be your
# real email; that's what lets your first signup claim the existing demo/real data.
LEGACY_HOUSEHOLD_OWNER_EMAIL="you@example.com"
LEGACY_HOUSEHOLD_INVITE_CODE="HOME-OWNER"
