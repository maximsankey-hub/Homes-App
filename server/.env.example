# Supabase Postgres — Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# Supabase Storage — Project Settings > API
SUPABASE_URL="https://xxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
SUPABASE_STORAGE_BUCKET="media"

# Auth — see README/plan for details. LEGACY_HOUSEHOLD_OWNER_EMAIL should be your
# real email; that's what lets your first signup claim the existing demo/real data.
LEGACY_HOUSEHOLD_OWNER_EMAIL="you@example.com"
LEGACY_HOUSEHOLD_INVITE_CODE="HOME-OWNER"

# Google Cloud Console (console.cloud.google.com) — a key restricted to the
# Geocoding API + Places API (New). Server-side only, never exposed to the browser.
GOOGLE_MAPS_SERVER_API_KEY="AIza..."

# RentCast (app.rentcast.io/app/api) — free tier, ~50 requests/month. Used to
# auto-fill sqft/beds/baths/year built/estimated value from an address.
RENTCAST_API_KEY="..."

# Pexels (pexels.com/api) — free, instant signup. Used by the one-time
# `npm run seed:style-photos -w server` script to curate the style-swipe photo
# catalog; not called at runtime.
PEXELS_API_KEY="..."
