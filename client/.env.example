# Supabase Auth — Project Settings > API. Use the anon/public key here (NOT the
# service role key — that one must never be exposed to the browser).
VITE_SUPABASE_URL="https://xxxxx.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."

# Google Cloud Console (console.cloud.google.com) — a key restricted to the
# Maps JavaScript API, with HTTP referrer restrictions (localhost + your Vercel
# domain). It's exposed to the browser, so restriction is the security boundary.
VITE_GOOGLE_MAPS_API_KEY="AIza..."
